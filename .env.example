# CoverSight - Environment Configuration
# Copy to .env and fill in your values

# Deepgram API Key (required for audio transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Cloud TTS: use GOOGLE_APPLICATION_CREDENTIALS or GOOGLE_API_KEY
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# GOOGLE_API_KEY=your_google_api_key

# Optional: API key for securing your endpoints
API_SECRET_KEY=your_optional_api_secret

# For whisper-gemini provider: local Whisper + Gemini translation + Deepgram analysis
# GOOGLE_API_KEY=your_google_api_key  # Gemini (translation)
# OPENAI_API_KEY=your_openai_key  # Fallback when local Whisper/PyTorch fails (e.g. Windows DLL)

# Policy embeddings (local storage path)
# POLICY_STORAGE_PATH=data/policy_embeddings.json

# Server
HOST=0.0.0.0
PORT=8000
